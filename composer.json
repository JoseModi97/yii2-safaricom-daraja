{
    "name": "josemodi97/yii2-safaricom-daraja",
    "description": "Yii2 Composer extension for Safaricom Daraja API requests based on the provided Postman collection.",
    "type": "yii2-extension",
    "keywords": ["yii2", "daraja", "mpesa", "safaricom", "composer-extension"],
    "license": "MIT",
    "require": {
        "php": ">=5.6",
        "yiisoft/yii2": "^2.0.13",
        "yiisoft/yii2-httpclient": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^5.7 || ^6.5 || ^7.5 || ^8.5 || ^9.6"
    },
    "autoload": {
        "psr-4": {
            "Safaricom\\Daraja\\": "src/"
        }
    },
    "extra": {
        "bootstrap": "Safaricom\\Daraja\\Bootstrap"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
