{
    "name": "josemodi97/yii2-safaricom-daraja",
    "description": "Yii2 Composer extension for Safaricom Daraja API requests based on the provided Postman collection.",
    "type": "yii2-extension",
    "keywords": ["yii2", "daraja", "mpesa", "safaricom", "safaricom-daraja", "mobile-money", "api-client", "composer-extension"],
    "homepage": "https://github.com/JoseModi97/yii2-safaricom-daraja",
    "license": "MIT",
    "authors": [
        {
            "name": "JoseModi97",
            "homepage": "https://github.com/JoseModi97"
        }
    ],
    "support": {
        "issues": "https://github.com/JoseModi97/yii2-safaricom-daraja/issues",
        "source": "https://github.com/JoseModi97/yii2-safaricom-daraja",
        "docs": "https://github.com/JoseModi97/yii2-safaricom-daraja#readme"
    },
    "require": {
        "php": ">=5.4",
        "yiisoft/yii2": "^2.0.6",
        "yiisoft/yii2-httpclient": "^2.0",
        "yidas/yii2-composer-bower-skip": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^4.8.36 || ^5.7 || ^6.5 || ^7.5 || ^8.5 || ^9.6"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "autoload": {
        "psr-4": {
            "Safaricom\\Daraja\\": "src/"
        }
    },
    "extra": {
        "bootstrap": "Safaricom\\Daraja\\Bootstrap"
    },
    "config": {
        "github-protocols": ["https"],
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
